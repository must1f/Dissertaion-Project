# PINN Financial Forecasting - Backend Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:password@localhost:5432/pinn_forecasting

# =============================================================================
# PATH CONFIGURATION
# =============================================================================

# Path to saved model weights (relative to backend/)
MODELS_DIR=../Models

# Path to evaluation results (relative to backend/)
RESULTS_DIR=../results

# Path to ML core source code (relative to backend/)
SRC_DIR=../src

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================

# Server host (0.0.0.0 for all interfaces, 127.0.0.1 for localhost only)
HOST=0.0.0.0

# Server port
PORT=8000

# Debug mode (true/false)
# Set to false in production
DEBUG=true

# =============================================================================
# CORS CONFIGURATION
# =============================================================================

# Allowed origins for CORS (comma-separated)
# Example: http://localhost:5173,https://example.com
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# =============================================================================
# OPTIONAL: SECURITY
# =============================================================================

# Secret key for token generation (generate a random string for production)
# SECRET_KEY=your-super-secret-key-here

# API key for protected endpoints (optional)
# API_KEY=your-api-key-here

# =============================================================================
# OPTIONAL: EXTERNAL APIS
# =============================================================================

# Alpha Vantage API key (for additional data sources)
# ALPHA_VANTAGE_API_KEY=your-alpha-vantage-key

# =============================================================================
# OPTIONAL: LOGGING
# =============================================================================

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Log file path (optional, logs to console if not set)
# LOG_FILE=logs/app.log
