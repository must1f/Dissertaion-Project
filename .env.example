# Database Configuration
POSTGRES_HOST=timescaledb
POSTGRES_PORT=5432
POSTGRES_DB=pinn_finance
POSTGRES_USER=pinn_user
POSTGRES_PASSWORD=pinn_password_change_me

# API Keys (REQUIRED - replace with your actual keys)
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here
# Note: yfinance doesn't require API key but has rate limits

# Model Configuration
RANDOM_SEED=42
DEVICE=cuda  # or cpu

# Data Configuration
START_DATE=2014-01-01
END_DATE=2024-01-01
TRAIN_RATIO=0.7
VAL_RATIO=0.15
TEST_RATIO=0.15

# Training Configuration
BATCH_SIZE=32
LEARNING_RATE=0.001
EPOCHS=100
EARLY_STOPPING_PATIENCE=10

# Physics Loss Weights
LAMBDA_PHYSICS=0.1
LAMBDA_GBM=0.1
LAMBDA_BS=0.1
LAMBDA_OU=0.1
LAMBDA_LANGEVIN=0.1

# Trading Configuration
INITIAL_CAPITAL=100000
TRANSACTION_COST=0.001  # 0.1%
MAX_POSITION_SIZE=0.2  # 20% of portfolio
STOP_LOSS=0.02  # 2%
TAKE_PROFIT=0.05  # 5%

# Logging
LOG_LEVEL=INFO
WANDB_API_KEY=your_wandb_key_here  # Optional
WANDB_PROJECT=pinn-financial-forecasting

# Web App
FLASK_ENV=development
STREAMLIT_SERVER_PORT=8501
