# PINN Financial Forecasting - Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=pinn_finance
POSTGRES_USER=pinn_user
POSTGRES_PASSWORD=pinn_password_change_me

# Full connection string (alternative to individual settings)
DATABASE_URL=postgresql://pinn_user:pinn_password_change_me@localhost:5432/pinn_finance

# =============================================================================
# API KEYS
# =============================================================================

# Alpha Vantage API key (optional - for additional data sources)
# Get your key at: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here

# =============================================================================
# MODEL CONFIGURATION
# =============================================================================

RANDOM_SEED=42
# Device options: cuda (NVIDIA GPU), mps (Apple Silicon), cpu (fallback)
# If set to an unavailable device, will auto-fallback to best available
DEVICE=cpu

# =============================================================================
# DATA CONFIGURATION
# =============================================================================

# Date range for training data (defaults to last 10 years if not set)
# Uncomment and set specific dates only if you need a fixed historical period
# START_DATE=2014-01-01
# END_DATE=2024-01-01
TRAIN_RATIO=0.7
VAL_RATIO=0.15
TEST_RATIO=0.15

# =============================================================================
# TRAINING CONFIGURATION
# =============================================================================

BATCH_SIZE=32
LEARNING_RATE=0.001
EPOCHS=100
EARLY_STOPPING_PATIENCE=10

# =============================================================================
# PHYSICS LOSS WEIGHTS
# =============================================================================

LAMBDA_PHYSICS=0.1
LAMBDA_GBM=0.1
LAMBDA_BS=0.1
LAMBDA_OU=0.1
LAMBDA_LANGEVIN=0.1

# =============================================================================
# TRADING CONFIGURATION
# =============================================================================

INITIAL_CAPITAL=100000
TRANSACTION_COST=0.001  # 0.1%
MAX_POSITION_SIZE=0.2   # 20% of portfolio
STOP_LOSS=0.02          # 2%
TAKE_PROFIT=0.05        # 5%

# =============================================================================
# LOGGING
# =============================================================================

LOG_LEVEL=INFO
WANDB_API_KEY=your_wandb_key_here  # Optional
WANDB_PROJECT=pinn-financial-forecasting

# =============================================================================
# WEB APPLICATION - BACKEND (FastAPI)
# =============================================================================

# Backend server configuration
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
DEBUG=true

# CORS configuration (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Path configuration (relative to backend/)
MODELS_DIR=../Models
RESULTS_DIR=../results
SRC_DIR=../src

# =============================================================================
# WEB APPLICATION - FRONTEND (React)
# =============================================================================

# These are set in frontend/.env for Vite
# VITE_API_URL=http://localhost:8000
# VITE_WS_URL=ws://localhost:8000

# =============================================================================
# LEGACY - STREAMLIT (for reference)
# =============================================================================

FLASK_ENV=development
STREAMLIT_SERVER_PORT=8501
